generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  password         String
  role             Role              @default(EMPLOYEE)
  departmentId     String?
  department       Department?       @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headOfDepartment Department?       @relation("DepartmentHead")
  status           Status            @default(ACTIVE)
  createdAssets    Asset[]           @relation("AssetCreator")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("users")
}

model Department {
  id                 String       @id @default(cuid())
  name               String       @unique
  code               String       @unique
  description        String?      @db.Text
  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments   Department[] @relation("DepartmentHierarchy")
  departmentHeadId   String?      @unique
  departmentHead     User?        @relation("DepartmentHead", fields: [departmentHeadId], references: [id])
  employees          User[]       @relation("DepartmentEmployees")
  assets             Asset[]
  status             Status       @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("departments")
}

model AssetCategory {
  id                    String   @id @default(cuid())
  name                  String   @unique
  description           String?  @db.Text
  defaultWarrantyMonths Int?
  assets                Asset[]
  status                Status   @default(ACTIVE)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("asset_categories")
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
}

model Asset {
  id            String            @id @default(cuid())
  assetTag      String            @unique
  name          String
  description   String?           @db.Text
  serialNumber  String            @unique
  categoryId    String
  category      AssetCategory     @relation(fields: [categoryId], references: [id])
  departmentId  String
  department    Department        @relation(fields: [departmentId], references: [id])
  location      String
  purchaseDate  DateTime
  purchaseCost  Float
  condition     AssetCondition    @default(NEW)
  status        AssetStatus       @default(AVAILABLE)
  manufacturer  String?
  model         String?
  vendor        String?
  warrantyStart DateTime?
  warrantyEnd   DateTime?
  imageUrl      String?           @db.Text
  qrCode        String?           @db.Text
  isBookable    Boolean           @default(false)
  createdBy     String
  creator       User              @relation("AssetCreator", fields: [createdBy], references: [id])
  allocations   AssetAllocation[]
  transfers     TransferRequest[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("assets")
}

enum AllocationStatus {
  ACTIVE
  RETURN_REQUESTED
  RETURNED
  OVERDUE
  TRANSFER_PENDING
  TRANSFERRED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

model AssetAllocation {
  id                 String           @id @default(cuid())
  assetId            String
  asset              Asset            @relation(fields: [assetId], references: [id])
  employeeId         String
  allocatedBy        String
  allocatedDate      DateTime         @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             AllocationStatus @default(ACTIVE)
  conditionAtIssue   String?
  conditionAtReturn  String?
  notes              String?          @db.Text
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([assetId])
  @@index([employeeId])
  @@map("asset_allocations")
}

model TransferRequest {
  id            String         @id @default(cuid())
  assetId       String
  asset         Asset          @relation(fields: [assetId], references: [id])
  requestedBy   String
  currentHolder String
  newHolder     String
  reason        String?        @db.Text
  status        TransferStatus @default(PENDING)
  approvedBy    String?
  requestedAt   DateTime       @default(now())
  approvedAt    DateTime?

  @@index([assetId])
  @@map("transfer_requests")
}

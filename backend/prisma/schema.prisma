generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
}

model User {
  id               String      @id @default(cuid())
  name             String
  email            String      @unique
  password         String
  role             Role        @default(EMPLOYEE)
  departmentId     String?
  department       Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headOfDepartment Department? @relation("DepartmentHead")
  status           Status      @default(ACTIVE)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("users")
}

model Department {
  id                 String       @id @default(cuid())
  name               String       @unique
  code               String       @unique
  description        String?      @db.Text
  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments   Department[] @relation("DepartmentHierarchy")
  departmentHeadId   String?      @unique
  departmentHead     User?        @relation("DepartmentHead", fields: [departmentHeadId], references: [id])
  employees          User[]       @relation("DepartmentEmployees")
  status             Status       @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("departments")
}

model AssetCategory {
  id                    String   @id @default(cuid())
  name                  String   @unique
  description           String?  @db.Text
  defaultWarrantyMonths Int?
  status                Status   @default(ACTIVE)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("asset_categories")
}

enum AllocationStatus {
  ACTIVE
  RETURN_REQUESTED
  RETURNED
  OVERDUE
  TRANSFER_PENDING
  TRANSFERRED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

// assetId is a plain column (not a relation) until the Asset module merges and
// defines Asset.id. employeeId/allocatedBy are also plain columns (rather than
// relations to User) for symmetry, since assetId can't be relational yet -
// service code resolves both via manual lookups instead of Prisma `include`.
model AssetAllocation {
  id                 String           @id @default(cuid())
  assetId            String
  employeeId         String
  allocatedBy        String
  allocatedDate      DateTime         @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             AllocationStatus @default(ACTIVE)
  conditionAtIssue   String?
  conditionAtReturn  String?
  notes              String?          @db.Text
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([assetId])
  @@index([employeeId])
  @@map("asset_allocations")
}

// See AssetAllocation comment above: assetId/requestedBy/currentHolder/newHolder/
// approvedBy are plain columns, not relations, until the Asset module merges.
model TransferRequest {
  id            String         @id @default(cuid())
  assetId       String
  requestedBy   String
  currentHolder String
  newHolder     String
  reason        String?        @db.Text
  status        TransferStatus @default(PENDING)
  approvedBy    String?
  requestedAt   DateTime       @default(now())
  approvedAt    DateTime?

  @@index([assetId])
  @@map("transfer_requests")
}
